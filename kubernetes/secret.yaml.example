apiVersion: v1
kind: Secret
metadata:
  name: magikup-secret
  labels:
    app: magikup
type: Opaque
stringData:
  # Fernet encryption key for endpoint password encryption
  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
  ENCRYPTION_KEY: "REPLACE_WITH_GENERATED_KEY"
